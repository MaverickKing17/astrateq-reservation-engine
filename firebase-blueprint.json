{
  "entities": {
    "Subscriber": {
      "title": "Subscriber",
      "description": "User email subscription for pre-launch updates",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The subscriber's email address"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the subscription was created"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed"],
          "description": "Subscription verification status"
        }
      },
      "required": ["email", "createdAt", "status"]
    }
  },
  "firestore": {
    "/subscribers/{email}": {
      "schema": "Subscriber",
      "description": "Collection of pre-launch subscribers keyed by email for uniqueness"
    }
  }
}
